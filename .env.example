TELEGRAM_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
DATABASE_PATH=capybara.db
TIMEZONE=Europe/Bucharest

# Dev Agent config (optional, only needed if you want to use /dev command)
ADMIN_TELEGRAM_ID=your_telegram_user_id
ANTHROPIC_API_KEY=your_anthropic_key_for_dev_agent
GITHUB_TOKEN=your_github_token
GITHUB_REPO=AndreiSecuQA/Capybara-bot

# Note: Get your Telegram user ID by messaging @userinfobot on Telegram
# Get Anthropic API key from console.anthropic.com
# Get GitHub token from github.com/settings/tokens (needs repo access)
